# Python .env file ..

# PYTHONPYCACHEPREFIX=__my_pycache

JUPYTER_PLATFORM_DIRS=1
PYDEVD_DISABLE_FILE_VALIDATION=1
# Allow tests to find sources
PYTHONPATH = src

# give 20 secs to complete : subprocess.getstatusoutput
PYDEVD_WARN_EVALUATION_TIMEOUT = 20

# stop nagging for updates
PIP_DISABLE_PIP_VERSION_CHECK=1

# stop neggin during debug
JUPYTER_PLATFORM_DIRS=1
PYDEVD_DISABLE_FILE_VALIDATION=1


MPFLASH_FIRMWARE=./scratch
MICROPY_DIR=~/micropython

# -----------------------------------------------------------------------------------------------
# HIL testing 
# -----------------------------------------------------------------------------------------------
# UF2 - RPI Pico2 on WSL
MPFLASH_HW_UF2_PORT=/dev/ttyACM1
MPFLASH_HW_UF2_FW=/mnt/c/Users/jos_v/Downloads/firmware/rp2/RPI_PICO2-v1.28.0.uf2

# DFU - PYBV11 on WSL
MPFLASH_HW_DFU_PORT=/dev/ttyACM0
MPFLASH_HW_DFU_FW=/mnt/c/Users/jos_v/Downloads/firmware/stm32/PYBV11-DP-v1.28.0.dfu

# PYOCD - PYBV11 on WSL
# MPFLASH_HW_PYOCD_PROBE=066CFF514949877187244446
MPFLASH_HW_PYOCD_PROBE=auto
MPFLASH_HW_PYOCD_PORT=/dev/ttyACM1
MPFLASH_HW_PYOCD_FW=/mnt/c/Users/jos_v/Downloads/firmware/stm32/PYBV11-DP-v1.28.0.hex
